programa {
  funcao inicio() {
    inteiro valor, i
    inteiro positivos = 0, negativos = 0, zeros = 0

    para(i = 1; i <= 20; i++){
      escreva("Digite o ", i, "º número inteiro: ")
      leia(valor)
      se (valor > 0){
        positivos++
      }senao se (valor < 0){
        negativos++
      }senao{
        zeros++
      }
    }
    escreva("\nQuantidade de números positivos: ", positivos)
    escreva("\nQuantidade de números negativos: ", negativos)
    escreva("\nQuantidade de zeros: ", zeros)
  }
}
