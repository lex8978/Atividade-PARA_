programa {
  funcao inicio() {
    inteiro valor, maior, menor

    escreva("Digite o 1º valor: ")
    leia(valor)

    maior = valor
    menor = valor

    para(inteiro i = 2; i <= 50; i++){
      escreva("Digite o ", i, "º valor: ")
      leia(valor)
      se (valor > maior){
        maior = valor
      }
      se (valor < menor){
        menor = valor
      }
    }
    escreva("\nO maior valor digitado foi: ", maior)
    escreva("\nO menor valor digitado foi: ", menor)
  }
}
