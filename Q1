programa {
  funcao inicio() {
    inteiro matri
    real nota
para(inteiro i=1; i<=75; i++){
  escreva("\nMatricula ")
  leia(matri)

  escreva("Nota ")
  leia(nota)

  se(nota>=0 e nota<=4.9){
    escreva("Conceito D\n")
  }senao se(nota<=6.9){
    escreva("Conceito C\n")
  }senao se(nota<=8.9){
    escreva("Conceito B\n")
  }senao{
    escreva("Conceito A\n")
  }
  escreva("Matricula, ",matri)
  escreva("\nNota, ",nota)
  
  
    
}

  }

}
